# Copy this file to `.env.local` and fill in your Supabase project values.
# Both variables must be prefixed NEXT_PUBLIC_ so they are exposed to the
# browser (the app reads Supabase directly from client-side code).

# Supabase project URL — found in Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon / public API key — Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Resend (email notifications) ──────────────────────────────────────
# Server-side only; do NOT prefix with NEXT_PUBLIC. If unset, the
# /api/notify route will log notifications to the server console instead
# of sending email (no errors thrown).

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Verified "from" address. For testing, Resend allows
# `onboarding@resend.dev`; for production use a domain you've verified in
# Resend.
RESEND_FROM_EMAIL=onboarding@resend.dev
